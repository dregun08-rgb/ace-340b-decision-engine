{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Streamlit Dashboard",
      "runtimeExecutable": "python3",
      "runtimeArgs": [
        "-m", "streamlit", "run", "app.py",
        "--server.port", "8501",
        "--server.headless", "true"
      ],
      "port": 8501
    },
    {
      "name": "FastAPI (uvicorn)",
      "runtimeExecutable": "python3",
      "runtimeArgs": [
        "-m", "uvicorn", "ace_340b_audit.api:app",
        "--host", "0.0.0.0",
        "--port", "8502",
        "--reload"
      ],
      "port": 8502
    }
  ]
}
